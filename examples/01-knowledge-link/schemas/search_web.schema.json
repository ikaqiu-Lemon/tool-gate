{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "examples/01-knowledge-link/schemas/search_web.schema.json",
  "title": "search_web contract (confounder tool; never passes PreToolUse in this example)",
  "type": "object",
  "required": ["input", "output"],
  "properties": {
    "input": {
      "type": "object",
      "required": ["query"],
      "additionalProperties": false,
      "properties": {
        "query": {"type": "string", "minLength": 1}
      }
    },
    "output": {
      "type": "object",
      "required": ["results"],
      "additionalProperties": false,
      "properties": {
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["url", "title", "snippet"],
            "additionalProperties": false,
            "properties": {
              "url":     {"type": "string", "format": "uri"},
              "title":   {"type": "string"},
              "snippet": {"type": "string"}
            }
          }
        }
      }
    }
  }
}
