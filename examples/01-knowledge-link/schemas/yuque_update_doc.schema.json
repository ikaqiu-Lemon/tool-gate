{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "examples/01-knowledge-link/schemas/yuque_update_doc.schema.json",
  "title": "yuque_update_doc contract (out-of-scope for example 01, used as deny target only)",
  "type": "object",
  "required": ["input", "output"],
  "properties": {
    "input": {
      "type": "object",
      "required": ["doc_id", "body_markdown"],
      "additionalProperties": false,
      "properties": {
        "doc_id":        {"type": "string", "minLength": 1},
        "body_markdown": {"type": "string"}
      }
    },
    "output": {
      "type": "object",
      "required": ["ok", "version"],
      "additionalProperties": false,
      "properties": {
        "ok":      {"type": "boolean"},
        "version": {"type": "integer", "minimum": 1}
      }
    }
  }
}
